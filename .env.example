
# ── MCP Server (Docker) ───────────────────────────────────────────────────────
# Port to expose on the host (container always listens on 8080)
TW_MCP_PORT=8080
# Log level: debug | info | warn | error
TW_MCP_LOG_LEVEL=info
# Log format: text | json
TW_MCP_LOG_FORMAT=text

# ── Teamwork API ──────────────────────────────────────────────────────────────
TEAMWORK_API_KEY=your_teamwork_api_key
TEAMWORK_WORKSPACE_URL=theapiguys.teamwork.com
TEAMWORK_PROJECT_ID=123456
TEAMWORK_TASKLIST_ID=1234567
TEAMWORK_PARENTTASK_ID=12345678

GITHUB_TOKEN=ghp_your_github_token
GITHUB_REPO=YourOrg/teamwork-mcp

DOCS_SSH_HOST=your.ssh.host
DOCS_SSH_USER=your_ssh_user
DOCS_SSH_PUBLIC_KEY=/Users/you/.ssh/id_rsa.pub
DOCS_SSH_PRIVATE_KEY=/Users/you/.ssh/id_rsa
DOCS_SSH_PATH=/srv/htdocs/dev/teamwork-mcp
