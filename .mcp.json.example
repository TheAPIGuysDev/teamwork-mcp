{
  "mcpServers": {
    "teamwork": {
      "command": "docker",
      "args": [
        "exec", "-i",
        "-e", "TW_MCP_BEARER_TOKEN",
        "-e", "TW_MCP_API_URL",
        "teamwork-mcp",
        "/bin/tw-mcp-stdio"
      ],
      "env": {
        "TW_MCP_BEARER_TOKEN": "your_teamwork_api_token_here",
        "TW_MCP_API_URL": "https://yourworkspace.teamwork.com"
      }
    }
  }
}
